{
    "name": "@vertigis/workflow-activities-state-manager",
    
    "version": "0.0.0-semantically-released",
    "description": "A deterministic, policy‑enforcing workflow engine designed for VertiGIS Studio Workflows.",
    "license": "MIT",
    "author": "VertiGIS",
        "homepage": "https://github.com/vertigis/workflow-activities-state-manager#readme",

    "type": "module",
        "repository": {
        "type": "git",
        "url": "git+https://github.com/vertigis/workflow-activities-state-manager.git"
    },
 "keywords": [
        "VertiGIS",
        "Geocortex",
        "Workflow",
        "State Management",
        "ArcGIS",
        "GIS"
    ],
    "scripts": {
        "build": "vertigis-workflow-sdk build",
        "generate": "vertigis-workflow-sdk generate",
        "start": "vertigis-workflow-sdk start",
        "lint": "eslint --max-warnings 0 --ext .ts,.tsx src/",
        "prettier": "prettier --write \"**/*.json\" \"**/*.js\" \"**/*.ts\" \"**/*.tsx\"",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "devDependencies": {
        "@vertigis/workflow": "5.50.0",
        "@vertigis/workflow-sdk": "6.0.0",
        "prettier": "^3.3.1",
        "typescript": "^5.4.3"
    },
    "overrides": {
        "@vertigis/react-ui": {
            "react": ">=18 <19",
            "react-dom": ">=18 <19"
        }
    },
    "browserslist": [
        "last 2 chrome versions",
        "last 2 edge versions",
        "last 2 firefox versions",
        "last 2 safari versions"
    ],
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged"
        }
    }
}
